{
  "name": "fuel-aware-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Node tooling for AI workflows around the Fuel-Aware backend",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "prisma:generate": "prisma generate",
    "lint": "tsc --noEmit",
    "test": "jest",
    "ai:check": "tsx tools/ai/check-env.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": ">=20.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": ">=4.0.0",
    "typescript": ">=5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  }
}
