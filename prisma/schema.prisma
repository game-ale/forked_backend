generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_DB_URL")
}

model Vehicle {
  vehicleId           String                @id @default(dbgenerated("gen_random_uuid()")) @map("vehicleId") @db.Uuid
  plateNumber         String                @map("plateNumber")
  label               String
  tankCapacityLiters  Decimal               @map("tankCapacityLiters") @db.Decimal(10, 2)
  assignedDriver      String?               @map("assignedDriver")
  status              String
  createdAt           DateTime              @default(now()) @map("createdAt") @db.Timestamptz(6)
  telemetry           TelemetryNormalized[]
  latestState         VehicleLatestState?
  deviceCredentials   DeviceCredential[]
  userVehicleAccesses UserVehicleAccess[]

  @@map("vehicles")
}

model TelemetryRaw {
  telemetryId String   @id @default(dbgenerated("gen_random_uuid()")) @map("telemetryId") @db.Uuid
  receivedAt  DateTime @default(now()) @map("receivedAt") @db.Timestamptz(6)
  payload     Json
  source      String

  @@map("telemetry_raw")
}

model TelemetryNormalized {
  telemetryId      String   @id @default(dbgenerated("gen_random_uuid()")) @map("telemetryId") @db.Uuid
  vehicleId        String   @map("vehicleId") @db.Uuid
  deviceId         String   @map("deviceId")
  timestamp        DateTime @map("timestamp") @db.Timestamptz(6)
  fuelLevelLiters  Decimal? @map("fuelLevelLiters") @db.Decimal(10, 2)
  fuelLevelPercent Decimal? @map("fuelLevelPercent") @db.Decimal(5, 2)
  latitude         Decimal? @db.Decimal(10, 7)
  longitude        Decimal? @db.Decimal(10, 7)
  speedKph         Decimal? @map("speedKph") @db.Decimal(10, 2)
  engineStatus     String?  @map("engineStatus")
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@map("telemetry_normalized")
}

model VehicleLatestState {
  vehicleId         String    @id @map("vehicleId") @db.Uuid
  lastSeenAt        DateTime? @map("lastSeenAt") @db.Timestamptz(6)
  fuelLevelLiters   Decimal?  @map("fuelLevelLiters") @db.Decimal(10, 2)
  fuelLevelPercent  Decimal?  @map("fuelLevelPercent") @db.Decimal(5, 2)
  latitude          Decimal?  @db.Decimal(10, 7)
  longitude         Decimal?  @db.Decimal(10, 7)
  engineStatus      String?   @map("engineStatus")
  deviceStatus      String?   @map("deviceStatus")
  currentAlertLevel String?   @map("currentAlertLevel")
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@map("vehicle_latest_state")
}

model UserProfile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?  @map("full_name")
  role      String   @default("viewer")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  vehicleAccess UserVehicleAccess[]

  @@map("user_profiles")
}

model UserVehicleAccess {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  vehicleId   String   @map("vehicle_id") @db.Uuid
  accessLevel String   @map("access_level") // 'assigned_driver' | 'viewer'
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle     @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  // Partial unique indexes for assigned_driver are enforced in Supabase SQL migrations.
  @@unique([userId, vehicleId], name: "user_vehicle_access_user_id_vehicle_id_key")
  @@index([userId], map: "user_vehicle_access_user_id_idx")
  @@index([vehicleId], map: "user_vehicle_access_vehicle_id_idx")
  @@map("user_vehicle_access")
}

model DeviceCredential {
  deviceId      String   @id @map("device_id")
  vehicleId     String   @map("vehicle_id") @db.Uuid
  tokenHash     String   @unique @map("token_hash")
  status        String   @default("active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastRotatedAt DateTime @default(now()) @map("last_rotated_at") @db.Timestamptz(6)

  vehicle Vehicle @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)

  @@index([vehicleId], map: "device_credentials_vehicle_id_idx")
  @@map("device_credentials")
}
